{
  "editor.fontFamily": "Cascadia Code",
  "editor.fontLigatures": true,
  "editor.fontSize": 16,
  "editor.rulers": [50, 72, 78, 80, 100, 120],
  "files.associations": {
    "Brewfile": "ruby",
    ".Brewfile": "ruby"
  },
  "gitProjectManager.baseProjectsFolders": ["$HOME/source"],
  "go.lintFlags": [
    "--enable-all",
    "--max-issues-per-linter=0",
    "--max-same-issues=0",
    "--tests"
  ],
  "go.lintOnSave": "file",
  "go.lintTool": "golangci-lint",
  "go.formatTool": "gofumports",
  "terminal.external.osxExec": "Hyper.app",
  "terminal.integrated.fontFamily": "Cascadia Code",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.scrollback": 10000,
  "workbench.colorTheme": "Material Theme",
  "yaml.customTags": [
    "!And",
    "!And sequence",
    "!If",
    "!If sequence",
    "!Not",
    "!Not sequence",
    "!Equals",
    "!Equals sequence",
    "!Or",
    "!Or sequence",
    "!FindInMap",
    "!FindInMap sequence",
    "!Base64",
    "!Join",
    "!Join sequence",
    "!Cidr",
    "!Ref",
    "!Sub",
    "!Sub sequence",
    "!GetAtt",
    "!GetAZs",
    "!ImportValue",
    "!ImportValue sequence",
    "!Select",
    "!Select sequence",
    "!Split",
    "!Split sequence"
  ],
  "yaml.validate": false,
  "extensions.showRecommendationsOnlyOnDemand": true,
  "[javascript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "vs-kubernetes": {
    "vs-kubernetes.helm-path.mac": "/Users/markayers/.vs-kubernetes/tools/helm/darwin-amd64/helm",
    "vs-kubernetes.minikube-path.mac": "/Users/markayers/.vs-kubernetes/tools/minikube/darwin-amd64/minikube",
    "vs-kubernetes.kubectl-path.mac": "/Users/markayers/.vs-kubernetes/tools/kubectl/kubectl",
    "vs-kubernetes.draft-path.mac": "/Users/markayers/.vs-kubernetes/tools/draft/darwin-amd64/draft"
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "workbench.startupEditor": "newUntitledFile",
  "window.zoomLevel": 0,
  "git.autofetch": true,
  "projectManager.git.baseFolders": [
    "~/source"
  ],
  "python.pythonPath": "/usr/local/bin/python3"
}
